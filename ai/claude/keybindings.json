{
  "$schema": "https://www.schemastore.org/claude-code-keybindings.json",
  "$docs": "https://code.claude.com/docs/en/keybindings",
  "bindings": [
    {
      "context": "Chat",
      "bindings": {
        "escape": null,
        "ctrl+q": "chat:cancel"
      }
    },
    {
      "context": "Autocomplete",
      "bindings": {
        "escape": null,
        "ctrl+q": "autocomplete:dismiss"
      }
    },
    {
      "context": "Confirmation",
      "bindings": {
        "escape": null,
        "ctrl+q": "confirm:no"
      }
    },
    {
      "context": "Transcript",
      "bindings": {
        "escape": null,
        "ctrl+q": "transcript:exit"
      }
    },
    {
      "context": "HistorySearch",
      "bindings": {
        "escape": null,
        "ctrl+q": "historySearch:accept"
      }
    },
    {
      "context": "Help",
      "bindings": {
        "escape": null,
        "ctrl+q": "help:dismiss"
      }
    },
    {
      "context": "Attachments",
      "bindings": {
        "escape": null,
        "ctrl+q": "attachments:exit"
      }
    },
    {
      "context": "Footer",
      "bindings": {
        "escape": null,
        "ctrl+q": "footer:clearSelection"
      }
    },
    {
      "context": "DiffDialog",
      "bindings": {
        "escape": null,
        "ctrl+q": "diff:dismiss"
      }
    },
    {
      "context": "Select",
      "bindings": {
        "escape": null,
        "ctrl+q": "select:cancel"
      }
    }
  ]
}
